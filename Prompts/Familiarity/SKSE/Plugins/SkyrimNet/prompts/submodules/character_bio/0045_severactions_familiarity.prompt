{% if render_mode == "full" or render_mode == "thoughts" or render_mode == "transform" or render_mode == "target" %}
{# Familiarity — what this NPC knows about the player. Sources:                 #}
{#   player_familiarity (tier + interactions + lastSeenDaysAgo), an LLM-        #}
{#   generated per-NPC blurb regenerated on first dialogue and every 100        #}
{#   exchanges thereafter. Blurb is produced by sever_reputation_assess.prompt. #}
{#                                                                              #}
{#   World knowledge is pulled here SOLELY to gate name-recognition: if the     #}
{#   player's name appears in any world-knowledge entry visible to this NPC     #}
{#   (per-character condition already evaluated by SkyrimNet), we let them      #}
{#   use the name even at tier=stranger. The world-knowledge CONTENT itself     #}
{#   is injected separately by SkyrimNet's own conditional-knowledge prompt —   #}
{#   we never re-render it here.                                                #}
{% if not is_follower(actorUUID) and not is_player(actorUUID) %}
{% set familiarity = player_familiarity(actorUUID) %}
{% if familiarity %}
{# World-knowledge name gate. Substring test against the per-NPC-filtered text. #}
{% set wk_text = get_world_knowledge(actorUUID) %}
{% set knows_name_via_world = wk_text and player.name in wk_text %}

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECTION 0: TEMPORAL CONTEXT — how long since last encounter        #}
{# ═══════════════════════════════════════════════════════════════════ #}

{% set days_ago = familiarity.lastSeenDaysAgo %}
{% set time_desc = "" %}
{% if days_ago and days_ago >= 1 %}
{% if days_ago > 30 %}{% set time_desc = "many weeks" %}
{% elif days_ago > 14 %}{% set time_desc = "a few weeks" %}
{% elif days_ago > 7 %}{% set time_desc = "about a week" %}
{% elif days_ago > 3 %}{% set time_desc = "several days" %}
{% else %}{% set time_desc = "a day or two" %}
{% endif %}
{% endif %}

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECTION 1: SHARED GUILD DETECTION                                  #}
{# Kept for relationship framing (camaraderie tone) — NOT for fame.   #}
{# Guild titles like "Harbinger" / "Arch-Mage" / "Listener" now only  #}
{# surface via world knowledge entries or an NPC's own memories.      #}
{# ═══════════════════════════════════════════════════════════════════ #}

{% set shared_guild = "" %}
{% if is_in_faction(actorUUID, "CompanionsFaction") and is_in_faction(player.UUID, "CompanionsFaction") %}{% set shared_guild = "The Companions" %}
{% elif is_in_faction(actorUUID, "CollegeofWinterholdFaction") and is_in_faction(player.UUID, "CollegeofWinterholdFaction") %}{% set shared_guild = "The College of Winterhold" %}
{% elif is_in_faction(actorUUID, "ThievesGuildFaction") and is_in_faction(player.UUID, "ThievesGuildFaction") %}{% set shared_guild = "The Thieves Guild" %}
{% elif is_in_faction(actorUUID, "DarkBrotherhoodFaction") and is_in_faction(player.UUID, "DarkBrotherhoodFaction") %}{% set shared_guild = "The Dark Brotherhood" %}
{% endif %}

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECTION 2: WHAT THIS NPC HAS PICKED UP ABOUT THE PLAYER            #}
{# rep_blurb = LLM-generated impression (per-NPC, regens on milestones)#}
{# World knowledge is NOT pulled here — SkyrimNet's own conditional-   #}
{# knowledge prompt already injects it per-character, and duplicating  #}
{# it here would double-feed the same information into the LLM.        #}
{# The assessment prompt (sever_reputation_assess) does use            #}
{# get_world_knowledge as raw material when it generates the blurb.    #}
{# ═══════════════════════════════════════════════════════════════════ #}

{% set rep_blurb = papyrus_util("GetStringValue", actorUUID, "SeverFamiliarity_Blurb", "") %}
{% set has_blurb = rep_blurb != "" %}

{# Name-recognition gate. Multiple sources can establish it:                   #}
{#   - Tier >= met_once: heard it during dialogue.                             #}
{#   - knows_name_via_world: an authored world-knowledge entry mentions the    #}
{#     player and reaches this NPC (reputation).                               #}
{#   - has_blurb: a stored impression exists, which means the NPC has at some  #}
{#     point in this save's history accumulated enough signal to warrant one.  #}
{#     Tier can drop back to "stranger" if SkyrimNet's recent dialogue window  #}
{#     rolls off (e.g., long absence, parallel-timeline saves), but the blurb  #}
{#     itself testifies that recognition was earned — don't gaslight the NPC.  #}
{% set knows_name = familiarity.tier == "met_once" or familiarity.tier == "acquainted" or familiarity.tier == "familiar" or knows_name_via_world or has_blurb %}

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECTION 3: OUTPUT                                                  #}
{# ═══════════════════════════════════════════════════════════════════ #}

{% if knows_name %}## What You Know About {{ player.name }}{% else %}## What You Know About This Person{% endif %}

{# ─── 3A: FAMILIARITY PROSE ─── #}
{% if shared_guild != "" %}
{# Shared-guild variants — relationship framing only, no fame titles #}
{% if familiarity.tier == "stranger" %}
{% if has_blurb %}
You are both members of {{ shared_guild }} and you have a settled impression of {{ player.name }} (rendered below), even though it has been a while since you last spoke directly.
- You can speak with the warmth of guild connection plus the weight of what you already think of them.
- Let your impression shape your manner, not just the bare fact of shared membership.
{% else %}
You are both members of {{ shared_guild }}, but you have not had a direct conversation with this person.
- You may have seen them around or heard their name mentioned by other members.
- Treat them as a fellow member you haven't met properly yet — warmer than a complete outsider, but don't assume familiarity beyond the guild connection.
{% if knows_name_via_world %}- The name **{{ player.name }}** is one you have heard tied to deeds beyond the guild. You may use it, but you do not know them personally — only their reputation.
{% endif %}
{% endif %}
{% elif familiarity.tier == "passing" %}
You are both members of {{ shared_guild }} and have exchanged words before, but you don't know this person's name.
- You recognize their face from around the guild, and they yours.
- Address them by what you can observe — their role, appearance, or a general greeting.
- If they introduce themselves or their name comes up, you can use it going forward.
{% if time_desc != "" %}- It has been {{ time_desc }} since your last encounter.
{% endif %}
{% elif familiarity.tier == "met_once" %}
You are both members of {{ shared_guild }} and have spoken a few times.
- You recognize them as a fellow member and know their name.
- You have a sense of who they are within the guild, but your personal connection is still developing.
- You can speak with the easy familiarity of shared membership — guild business, mutual acquaintances, recent goings-on.
{% if time_desc != "" %}- It has been {{ time_desc }} since you last spoke.
{% endif %}
{% elif familiarity.tier == "acquainted" %}
You are both members of {{ shared_guild }} and have had many conversations.
- You know them well as a fellow member and have a solid sense of their character.
- You can speak freely about guild matters and personal topics alike.
- There is a natural camaraderie from shared experiences within the guild.
{% if time_desc != "" %}- It has been {{ time_desc }} since you last saw each other.
{% endif %}
{% elif familiarity.tier == "familiar" %}
You are both members of {{ shared_guild }} and know each other well after many conversations.
- You can speak openly, reference shared history, and react with the comfort of a long acquaintance.
- Your opinions about them are well-formed — let past interactions shape how you engage.
{% if time_desc != "" %}- It has been {{ time_desc }} since you last crossed paths.
{% endif %}
{% endif %}
{% else %}
{# Standard (non-shared-guild) variants #}
{% if familiarity.tier == "stranger" %}
{% if has_blurb %}
You have not had a recent direct conversation with this person, but you do have a settled impression of them (rendered below). They are not a stranger to you in the deeper sense — at some point you accumulated enough exposure to form an opinion, even if it has been a long time since you actually spoke.
- You may use the name **{{ player.name }}** if it fits your role and the situation.
- Let your impression of them shape your manner — warm, wary, dismissive, whatever fits the relationship as it stands.
- If your character description establishes a prior relationship, that backstory takes precedence.
{% elif knows_name_via_world %}
You have never spoken to this person, but the name **{{ player.name }}** is one you have heard tied to deeds beyond their own circle.
- Use the name if it fits, but you do not know them personally — only their reputation. Recognition is provisional until they confirm.
- Let what you know of {{ player.name }} (already in your context) shape your manner — awed, wary, deferential, dismissive, whatever fits the deeds and your role.
- If your character description establishes a prior relationship with this person, that backstory takes precedence.
{% else %}
You have not spoken with this person directly. Default to a stranger's manner in keeping with your personality and role.
- Default to indirect address (their bearing, gear, role) unless an introduction or your character description establishes the name.
- If memories, recent events, or other context elsewhere in this prompt clearly establish recognition, trust that signal — but don't invent familiarity that isn't grounded there.
{% endif %}
{% elif familiarity.tier == "passing" %}
You have spoken to this person before, but you do not know their name.
- You may recognize their face or voice from a previous encounter.
- Do not use their name — you haven't learned it yet. Address them by observation (appearance, gear, role) or a general greeting.
- If they introduce themselves or their name comes up naturally, you can use it going forward.
- You are not strangers, but you are not familiar either — brief, polite, and somewhat guarded.
{% if time_desc != "" %}- It has been {{ time_desc }} since your last encounter.
{% endif %}
{% elif familiarity.tier == "met_once" %}
You have spoken to this person a few times before. You recognize them.
- You know their name and have a general impression of them.
- Polite and somewhat familiar, but you don't know them well yet.
- You may reference that you've talked before, but don't assume deep knowledge of their life or motivations.
{% if time_desc != "" %}- It has been {{ time_desc }} since you last spoke.
{% endif %}
{% elif familiarity.tier == "acquainted" %}
You have had several conversations with this person. You know who they are.
- You recognize them and can greet them by name.
- You have a sense of their personality and intentions based on prior interactions.
- Friendly but not deeply intimate unless your relationship has developed that way.
{% if time_desc != "" %}- It has been {{ time_desc }} since you last saw each other.
{% endif %}
{% elif familiarity.tier == "familiar" %}
You know this person well after many conversations. You have a strong sense of who they are.
- You can speak openly, reference shared history, and react with the comfort of a long acquaintance.
- Your opinions about them are well-formed — let past interactions and impressions shape how you engage.
{% if time_desc != "" %}- It has been {{ time_desc }} since you last crossed paths.
{% endif %}
{% endif %}
{% endif %}

{# ─── 3B: IMPRESSION (blurb only) ─── #}
{# The blurb is the NPC's personal take. It's not a recitation cue — it informs #}
{# tone and attitude. World knowledge is not rendered here (SkyrimNet's own     #}
{# conditional-knowledge prompt injects it separately); it was already folded   #}
{# into the blurb when the blurb was generated.                                 #}
{% if has_blurb %}

{% if familiarity.tier == "stranger" or familiarity.tier == "passing" %}
{% if knows_name %}What you have heard or sense about {{ player.name }}{% else %}What you have heard or sense about this person{% endif %}:
{{ rep_blurb }}
Do not recite these details. Let them inform your tone and attitude naturally.
{% elif familiarity.tier == "met_once" %}
Now that you know {{ player.name }}'s name, you can connect it to what you have heard:
{{ rep_blurb }}
Let this recognition color how you treat them going forward. It should surface naturally, not all at once.
{% elif familiarity.tier == "acquainted" %}
Your impression of {{ player.name }}:
{{ rep_blurb }}
This is settled — it does not need to be stated, it shapes how you interact.
{% elif familiarity.tier == "familiar" %}
How you see {{ player.name }} after all this time:
{{ rep_blurb }}
{% endif %}
{% endif %}

{% endif %}{# end familiarity truthy #}
{% endif %}{# end not follower, not player #}
{% endif %}{# end render_mode #}
