{% set fUUID = formid_to_uuid(f.formId) %}
{% if fUUID and fUUID != 0 %}
{% set fNpc = decnpc(fUUID) %}
{% if fNpc and fNpc.name %}
{% set followerCount = followerCount + 1 %}
