{% elif mq_fame >= 1 and is_whiterun_local %}{% set knows_mq = true %}{% set mq_knowledge = "dragon_slayer" %}
{% endif %}

{# Dawnguard knowledge #}
{% set knows_dg = false %}
{% set dg_knowledge = "" %}
{% if dg_fame >= 3 and npc_conn >= 2 %}{% set knows_dg = true %}{% set dg_knowledge = "ended" %}
{% elif dg_fame >= 2 and npc_conn >= 3 %}{% set knows_dg = true %}{% set dg_knowledge = "involved" %}
