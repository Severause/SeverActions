{# Merged Familiarity & Reputation System — what this NPC knows about the player #}
{% if render_mode == "full" or render_mode == "thoughts" or render_mode == "transform" or render_mode == "target" %}
{% if not is_follower(actorUUID) and not is_player(actorUUID) %}
{% set familiarity = player_familiarity(actorUUID) %}
{% if familiarity %}

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECTION 1: NPC ROLE CLASSIFICATION                                 #}
{# ═══════════════════════════════════════════════════════════════════ #}

{% set is_innkeeper = is_in_faction(actorUUID, "JobInnkeeperFaction") %}
{% set is_bard = is_in_faction(actorUUID, "JobBardFaction") or is_in_faction(actorUUID, "BardSingerFaction") %}
{% set is_merchant = is_in_faction(actorUUID, "JobMerchantFaction") %}
{% set is_guard = is_in_faction(actorUUID, "GuardDialogueFaction") %}
{% set is_jarl = is_in_faction(actorUUID, "JobJarlFaction") %}
{% set is_bandit = is_in_faction(actorUUID, "BanditFaction") or is_in_faction(actorUUID, "BanditFriendFaction") %}
{% set is_fence = is_in_faction(actorUUID, "RiftenRatwayFactionNeutral") or is_in_faction(actorUUID, "RiftenTGHeadquartersFaction") %}
{% set is_criminal = is_bandit or is_fence or is_in_faction(actorUUID, "CrimeFactionThievesGuild") %}

{# Connectedness: how socially plugged-in this NPC is #}
{% set npc_conn = 1 %}
{% if is_jarl %}{% set npc_conn = 5 %}
{% elif is_innkeeper %}{% set npc_conn = 4 %}
{% elif is_bard %}{% set npc_conn = 4 %}
{% elif is_guard %}{% set npc_conn = 3 %}
{% elif is_merchant %}{% set npc_conn = 3 %}
{% elif is_criminal %}{% set npc_conn = 3 %}
{% endif %}

{# NPC guild membership #}
{% set npc_is_comp = is_in_faction(actorUUID, "CompanionsFaction") %}
{% set npc_is_college = is_in_faction(actorUUID, "CollegeofWinterholdFaction") %}
{% set npc_is_tg = is_in_faction(actorUUID, "ThievesGuildFaction") %}
{% set npc_is_db = is_in_faction(actorUUID, "DarkBrotherhoodFaction") %}

{# NPC locality (faction-based, no fragile string matching) #}
{% set is_riften_local = is_in_faction(actorUUID, "TownRiftenFaction") or is_in_faction(actorUUID, "CrimeFactionRift") %}
{% set is_whiterun_local = is_in_faction(actorUUID, "TownWhiterunFaction") or is_in_faction(actorUUID, "CrimeFactionWhiterun") %}
{% set is_winterhold_local = is_in_faction(actorUUID, "TownWinterholdFaction") %}

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECTION 2: SHARED GUILD DETECTION                                  #}
{# ═══════════════════════════════════════════════════════════════════ #}

{% set shared_guild = "" %}
{% set player_is_comp = is_in_faction(player.UUID, "CompanionsFaction") %}
{% set player_is_college = is_in_faction(player.UUID, "CollegeofWinterholdFaction") %}
{% set player_is_tg = is_in_faction(player.UUID, "ThievesGuildFaction") %}
{% set player_is_db = is_in_faction(player.UUID, "DarkBrotherhoodFaction") %}

{% if npc_is_comp and player_is_comp %}{% set shared_guild = "The Companions" %}
{% elif npc_is_college and player_is_college %}{% set shared_guild = "The College of Winterhold" %}
{% elif npc_is_tg and player_is_tg %}{% set shared_guild = "The Thieves Guild" %}
{% elif npc_is_db and player_is_db %}{% set shared_guild = "The Dark Brotherhood" %}
{% endif %}

{# ═══════════════════════════════════════════════════════════════════ #}
{# SECTION 3: PLAYER GUILD PROGRESSION (fame levels)                  #}
{# Faction checks first (cheapest), quest stages as fallback          #}
{# ═══════════════════════════════════════════════════════════════════ #}

{# --- Companions --- #}
{% set comp_fame = 0 %}
{% set comp_title = "" %}
{% if player_is_comp %}
{% if is_in_faction(player.UUID, "CompanionsHarbingerFaction") %}{% set comp_fame = 5 %}
{% elif is_in_faction(player.UUID, "CompanionsCircle") %}{% set comp_fame = 4 %}
{% elif get_quest_stage("C06", false) >= 200 %}{% set comp_fame = 4 %}
{% elif get_quest_stage("C03", false) >= 200 %}{% set comp_fame = 3 %}
{% elif get_quest_stage("C01", false) >= 200 %}{% set comp_fame = 2 %}
{% elif get_quest_stage("C00", false) >= 100 %}{% set comp_fame = 1 %}
{% else %}{% set comp_fame = 1 %}
{% endif %}
{% endif %}
{% if comp_fame == 5 %}{% set comp_title = "the Harbinger of the Companions" %}
{% elif comp_fame == 4 %}{% set comp_title = "a member of the Circle" %}
