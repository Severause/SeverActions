{# Companions knowledge #}
{% set knows_comp = false %}
{% set comp_knowledge = "" %}
{% if npc_is_comp and comp_fame >= 1 %}{% set knows_comp = true %}{% set comp_knowledge = "full" %}
{% elif is_whiterun_local and comp_fame >= 1 %}{% set knows_comp = true %}{% set comp_knowledge = "local" %}
{% elif (is_guard or is_innkeeper) and comp_fame >= 3 %}{% set knows_comp = true %}{% set comp_knowledge = "reputation" %}
{% elif (is_innkeeper or is_bard or is_merchant) and comp_fame >= 4 %}{% set knows_comp = true %}{% set comp_knowledge = "fame" %}
{% elif npc_conn >= 2 and comp_fame >= 5 %}{% set knows_comp = true %}{% set comp_knowledge = "legend" %}
{% endif %}

{# College knowledge #}
{% set knows_mg = false %}
{% set mg_knowledge = "" %}
{% if npc_is_college and mg_fame >= 1 %}{% set knows_mg = true %}{% set mg_knowledge = "full" %}
{% elif is_winterhold_local and mg_fame >= 1 %}{% set knows_mg = true %}{% set mg_knowledge = "local" %}
{% elif (is_bard or is_jarl) and mg_fame >= 4 %}{% set knows_mg = true %}{% set mg_knowledge = "scholarly" %}
{% elif npc_conn >= 3 and mg_fame >= 5 %}{% set knows_mg = true %}{% set mg_knowledge = "legend" %}
{% endif %}

{# Thieves Guild knowledge #}
{% set knows_tg = false %}
{% set tg_knowledge = "" %}
{% if npc_is_tg and tg_fame >= 1 %}{% set knows_tg = true %}{% set tg_knowledge = "full" %}
{% elif is_fence and tg_fame >= 1 %}{% set knows_tg = true %}{% set tg_knowledge = "underworld" %}
{% elif is_criminal and tg_fame >= 3 %}{% set knows_tg = true %}{% set tg_knowledge = "criminal_rumor" %}
