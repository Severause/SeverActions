{% set mg_title = "" %}
{% if player_is_college %}
{% if is_in_faction(player.UUID, "CollegeofWinterholdArchMageFaction") %}{% set mg_fame = 5 %}
{% elif get_quest_stage("MG07", false) >= 200 %}{% set mg_fame = 4 %}
{% elif get_quest_stage("MG04", false) >= 200 %}{% set mg_fame = 3 %}
{% elif get_quest_stage("MG02", false) >= 200 %}{% set mg_fame = 2 %}
