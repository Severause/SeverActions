{% if get_quest_stage("DBDestroy", false) >= 10 %}{% set db_destroyed = true %}{% set db_fame = 5 %}
{% elif player_is_db %}
{% if get_quest_stage("DB11", false) >= 200 %}{% set db_fame = 5 %}
{% elif get_quest_stage("DB10", false) >= 200 %}{% set db_fame = 4 %}
