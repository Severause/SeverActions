{% elif is_riften_local and tg_fame >= 4 %}{% set knows_tg = true %}{% set tg_knowledge = "local_rumor" %}
{% elif (is_innkeeper or is_bard) and tg_fame >= 5 %}{% set knows_tg = true %}{% set tg_knowledge = "legend" %}
{% endif %}

{# Dark Brotherhood knowledge #}
{% set knows_db = false %}
{% set db_knowledge = "" %}
{% if npc_is_db and db_fame >= 2 and not db_destroyed %}{% set knows_db = true %}{% set db_knowledge = "family" %}
{% elif db_destroyed and npc_conn >= 3 %}{% set knows_db = true %}{% set db_knowledge = "destroyer" %}
{% endif %}

{# Main Quest / Dragonborn knowledge #}
{% set knows_mq = false %}
{% set mq_knowledge = "" %}
{% if mq_fame >= 5 %}{% set knows_mq = true %}{% set mq_knowledge = "legend" %}
{% elif mq_fame >= 4 and npc_conn >= 2 %}{% set knows_mq = true %}{% set mq_knowledge = "seeker" %}
