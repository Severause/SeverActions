{% set dg_fame = 0 %}
{% if get_quest_stage("DLC1VQ08", false) >= 200 %}{% set dg_fame = 3 %}
{% elif get_quest_stage("DLC1VQ05", false) >= 200 %}{% set dg_fame = 2 %}
