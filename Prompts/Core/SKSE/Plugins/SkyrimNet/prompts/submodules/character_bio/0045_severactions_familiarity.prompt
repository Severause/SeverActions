{# --- Main Quest / Dragonborn --- #}
{% set mq_fame = 0 %}
{% set mq_title = "" %}
{% if get_quest_stage("MQ305", false) >= 200 %}{% set mq_fame = 5 %}
{% elif get_quest_stage("MQ301", false) >= 220 %}{% set mq_fame = 4 %}
